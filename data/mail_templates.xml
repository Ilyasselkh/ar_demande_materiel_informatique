        <!-- 5) Emprunté -> Demandeur -->
        <record id="mail_template_it_borrowed_to_demandeur" model="mail.template">
            <field name="name">IT - Matériel emprunté (Demandeur)</field>
            <field name="model_id" ref="model_ar_it_demande"/>
            <field name="subject">[Demande IT] {{ object.name }} - Matériel emprunté</field>
            <field name="email_from">MI Workflow &lt;DM-ARMaroc@araymond.com&gt;</field>
            <field name="email_to"></field>

            <field name="body_html" type="html">
                <div>
                    <p>Bonjour,</p>
                    <p>
                        Votre demande <strong><t t-out="object.name"/></strong> a été marquée comme <strong>Empruntée</strong>.
                    </p>

                    <p>
                        <strong>Expression de besoin :</strong> Emprunter<br/>
                        <strong>Période d’emprunt :</strong>
                        du <strong><t t-out="object.periode_from or ''"/></strong>
                        au <strong><t t-out="object.periode_to or ''"/></strong>
                    </p>

                    <p>
                        <strong>Demandeur :</strong> <t t-out="object.demandeur_id.name or ''"/><br/>
