<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- ===================================================== -->
        <!-- Helper (snippet) : bloc affichage Expression de besoin -->
        <!-- NOTE: Odoo/QWeb ne supporte pas les "includes" ici,
             donc on répète le bloc dans chaque template. -->
        <!-- ===================================================== -->


        <!-- 1) Création -> Manager N+1 -->
        <record id="mail_template_it_new_to_manager" model="mail.template">
            <field name="name">IT - Nouvelle demande (Manager N+1)</field>
            <field name="model_id" ref="model_ar_it_demande"/>
            <field name="subject">[Demande IT] {{ object.name }} - Validation N+1 requise</field>
            <field name="email_from">MI Workflow &lt;DM-ARMaroc@araymond.com&gt;</field>
            <field name="email_to"></field>

            <field name="body_html" type="html">
                <div>
                    <p>Bonjour,</p>
                    <p>
                        Une <strong>nouvelle demande de matériel informatique</strong> a été créée et nécessite votre validation (N+1).
                    </p>

                    <p>
                        <strong>Référence :</strong> <t t-out="object.name"/><br/>
                        <strong>Demandeur :</strong> <t t-out="object.demandeur_id.name or ''"/><br/>
                        <strong>Département :</strong> <t t-out="object.department_id.name or ''"/><br/>
                        <strong>Manager N+1 :</strong> <t t-out="object.manager_n1_id.name or ''"/><br/>
                        <strong>Expression de besoin :</strong>
                        <t t-if="object.expression_besoin == 'nouveau'">Nouveau besoin</t>
                        <t t-elif="object.expression_besoin == 'remplacement'">Remplacement</t>
                        <t t-elif="object.expression_besoin == 'emprunter'">Emprunter</t>
                        <t t-else="">-</t>
                        <br/>

                        <t t-if="object.expression_besoin == 'nouveau'">
                            <strong>Date de besoin :</strong> <t t-out="object.date_besoin or ''"/><br/>
                        </t>

                        <t t-if="object.expression_besoin == 'remplacement'">
                            <strong>Date de remplacement :</strong> <t t-out="object.date_remplacement or ''"/><br/>
                        </t>

                        <t t-if="object.expression_besoin == 'emprunter'">
                            <strong>Période d’emprunt :</strong>
                            du <strong><t t-out="object.periode_from or ''"/></strong>
                            au <strong><t t-out="object.periode_to or ''"/></strong>
                            <br/>
                        </t>
                    </p>

                    <t t-set="base_url" t-value="object.get_base_url()"/>
                    <div style="margin: 16px 0px;">
                        <a t-attf-href="{{ base_url }}/web#id={{ object.id }}&amp;model=ar.it.demande&amp;view_type=form"
                           style="background-color:#1481f4;padding:8px 16px;text-decoration:none;color:#fff;border-radius:5px;font-size:13px;">
                            Accéder à la demande
                        </a>
                    </div>

                    <p>Merci.</p>
                </div>
            </field>
        </record>


        <!-- 2) N+1 valide -> Demandeur -->
        <record id="mail_template_it_approved_to_demandeur" model="mail.template">
            <field name="name">IT - Demande validée (Demandeur)</field>
            <field name="model_id" ref="model_ar_it_demande"/>
            <field name="subject">[Demande IT] {{ object.name }} - Validée par votre manager</field>
            <field name="email_from">MI Workflow &lt;DM-ARMaroc@araymond.com&gt;</field>
            <field name="email_to"></field>

            <field name="body_html" type="html">
                <div>
                    <p>Bonjour,</p>
                    <p>
                        Votre demande <strong><t t-out="object.name"/></strong> a été <strong>validée</strong> par votre manager N+1.
                    </p>

                    <p>
                        <strong>Expression de besoin :</strong>
                        <t t-if="object.expression_besoin == 'nouveau'">Nouveau besoin</t>
                        <t t-elif="object.expression_besoin == 'remplacement'">Remplacement</t>
                        <t t-elif="object.expression_besoin == 'emprunter'">Emprunter</t>
                        <t t-else="">-</t>
                        <br/>

                        <t t-if="object.expression_besoin == 'nouveau'">
                            <strong>Date de besoin :</strong> <t t-out="object.date_besoin or ''"/><br/>
                        </t>

                        <t t-if="object.expression_besoin == 'remplacement'">
                            <strong>Date de remplacement :</strong> <t t-out="object.date_remplacement or ''"/><br/>
                        </t>

                        <t t-if="object.expression_besoin == 'emprunter'">
                            <strong>Période d’emprunt :</strong>
                            du <strong><t t-out="object.periode_from or ''"/></strong>
                            au <strong><t t-out="object.periode_to or ''"/></strong>
                            <br/>
                        </t>
                    </p>

                    <t t-set="base_url" t-value="object.get_base_url()"/>
                    <div style="margin: 16px 0px;">
                        <a t-attf-href="{{ base_url }}/web#id={{ object.id }}&amp;model=ar.it.demande&amp;view_type=form"
                           style="background-color:#16a34a;padding:8px 16px;text-decoration:none;color:#fff;border-radius:5px;font-size:13px;">
                            Voir la demande
                        </a>
                    </div>

                    <p>Merci.</p>
                </div>
            </field>
        </record>


        <!-- 3) Passage en traitement -> Traiteurs -->
        <record id="mail_template_it_processing_to_traiteurs" model="mail.template">
            <field name="name">IT - Demande à traiter (Traiteurs)</field>
            <field name="model_id" ref="model_ar_it_demande"/>
            <field name="subject">[Demande IT] {{ object.name }} - Nouvelle demande à traiter</field>
            <field name="email_from">MI Workflow &lt;DM-ARMaroc@araymond.com&gt;</field>
            <field name="email_to"></field>

            <field name="body_html" type="html">
                <div>
                    <p>Bonjour,</p>
                    <p>
                        Une demande de matériel informatique est passée à l’état <strong>Traitement</strong> et nécessite votre prise en charge.
                    </p>

                    <p>
                        <strong>Référence :</strong> <t t-out="object.name"/><br/>
                        <strong>Demandeur :</strong> <t t-out="object.demandeur_id.name or ''"/><br/>
                        <strong>Département :</strong> <t t-out="object.department_id.name or ''"/><br/>

                        <strong>Expression de besoin :</strong>
                        <t t-if="object.expression_besoin == 'nouveau'">Nouveau besoin</t>
                        <t t-elif="object.expression_besoin == 'remplacement'">Remplacement</t>
                        <t t-elif="object.expression_besoin == 'emprunter'">Emprunter</t>
                        <t t-else="">-</t>
                        <br/>

                        <t t-if="object.expression_besoin == 'nouveau'">
                            <strong>Date de besoin :</strong> <t t-out="object.date_besoin or ''"/><br/>
                        </t>

                        <t t-if="object.expression_besoin == 'remplacement'">
                            <strong>Date de remplacement :</strong> <t t-out="object.date_remplacement or ''"/><br/>
                        </t>

                        <t t-if="object.expression_besoin == 'emprunter'">
                            <strong>Période d’emprunt :</strong>
                            du <strong><t t-out="object.periode_from or ''"/></strong>
                            au <strong><t t-out="object.periode_to or ''"/></strong>
                            <br/>
                        </t>
                    </p>

                    <t t-set="base_url" t-value="object.get_base_url()"/>
                    <div style="margin: 16px 0px;">
                        <a t-attf-href="{{ base_url }}/web#id={{ object.id }}&amp;model=ar.it.demande&amp;view_type=form"
                           style="background-color:#f59e0b;padding:8px 16px;text-decoration:none;color:#111;border-radius:5px;font-size:13px;">
                            Accéder à la demande
                        </a>
                    </div>

                    <p>Merci.</p>
                </div>
            </field>
        </record>


