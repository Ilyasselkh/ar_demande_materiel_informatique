<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List -->
    <record id="view_ar_it_documentation_list" model="ir.ui.view">
        <field name="name">ar.it.documentation.list</field>
        <field name="model">ar.it.documentation</field>
        <field name="arch" type="xml">
            <list>
                <field name="description"/>
                <field name="file_name"/>
                <field name="link_url"/>
                <field name="created_by"/>
                <field name="created_on"/>
            </list>
        </field>
    </record>

    <!-- Form -->
    <record id="view_ar_it_documentation_form" model="ir.ui.view">
        <field name="name">ar.it.documentation.form</field>
        <field name="model">ar.it.documentation</field>
        <field name="arch" type="xml">
            <form string="Documentation">
                <sheet>
                    <group>
                        <field name="description"/>
                        <field name="file_data" filename="file_name"/>
                        <field name="file_name" invisible="True"/>
                        <field name="link_url" placeholder="https://..."/>
                    </group>

                    <group string="Audit">
                        <field name="created_by" readonly="True"/>
                        <field name="created_on" readonly="True"/>
                    </group>

                    <div class="oe_chatter">
                        <field name="message_follower_ids" widget="mail_followers"/>
                        <field name="activity_ids" widget="mail_activity"/>
                        <field name="message_ids" widget="mail_thread"/>
                    </div>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_ar_it_documentation" model="ir.actions.act_window">
        <field name="name">Documentation</field>
        <field name="res_model">ar.it.documentation</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>