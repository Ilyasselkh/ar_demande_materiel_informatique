<odoo>
    <record id="view_ar_it_traiteur_list" model="ir.ui.view">
        <field name="name">ar.it.traiteur.list</field>
        <field name="model">ar.it.traiteur</field>
        <field name="arch" type="xml">
            <list>
                <field name="employee_id"/>
                <field name="is_available" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="view_ar_it_traiteur_form" model="ir.ui.view">
        <field name="name">ar.it.traiteur.form</field>
        <field name="model">ar.it.traiteur</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="employee_id"/>
                        <field name="is_available" widget="boolean_toggle"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_ar_it_traiteur" model="ir.actions.act_window">
        <field name="name">Personnes qui traite</field>
        <field name="res_model">ar.it.traiteur</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>